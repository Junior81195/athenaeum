# Athenaeum — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Database (required) ────────────────────────────────────────────────────────
ATHENAEUM_DB_PASSWORD=changeme

# ── LLM (default: free-llm gateway via container network) ─────────────────────
# The docker-compose.yml wires this to the free-llm gateway automatically.
# Override here only if you want a different provider.
LLM_PROVIDER=openai
LLM_MODEL=auto
LLM_API_KEY=free
LLM_BASE_URL=http://free_llm_api:8000/v1

# ── Frontend (baked into Next.js at build time) ────────────────────────────────
NEXT_PUBLIC_API_URL=https://athenaeum.herakles.dev
